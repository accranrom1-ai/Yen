# Xử lý khi nhấn vào nút bấm "Làm mới số liệu" trên bảng admin
async def admin_button_click(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    query = update.callback_query
    await query.answer() # Thông báo cho Telegram biết đã nhận được lệnh bấm nút
    
    if not is_admin(update):
        return
    
    if query.data == "refresh_stats":
        keyboard = [[InlineKeyboardButton("🔄 Làm mới số liệu", callback_data="refresh_stats")]]
        reply_markup = InlineKeyboardMarkup(keyboard)
        
        # Sửa tin nhắn cũ thành dữ liệu mới cập nhật để tránh rác hộp thoại
        try:
            await query.edit_message_text(
                generate_admin_text(),
                parse_mode=ParseMode.MARKDOWN,
                reply_markup=reply_markup
            )
        except Exception:
            pass # Tránh báo lỗi nếu dữ liệu không có gì thay đổi khi bấm liên tục

# Lệnh phát tín hiệu hàng loạt (/baolenh [phiên] [tài/xỉu])
async def baolenh(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not is_admin(update):
        return
    
    if not context.args or len(context.args) < 2:
        await update.message.reply_text("⚠️ *Sai cú pháp!* Vui lòng gõ dạng:\n`/baolenh [Số_Phiên] [TAI/XIU]`", parse_mode=ParseMode.MARKDOWN)
        return

    phien = context.args[0]
    ketqua_raw = context.args[1].upper()
    ketqua = "🔴 TÀI" if "TAI" in ketqua_raw else "🟢 XỈU" if "XIU" in ketqua_raw else ketqua_raw

    tin_nhan_tong = (
        f"📢 *THÔNG BÁO LỆNH TỪ ADMIN*\n"
        f"--------------------------------------\n"
        f"🆔 *Phiên số:* #{phien}\n"
        f"🔮 *Hệ thống báo:* {ketqua}\n"
        f"⚡ *Vào lệnh ngay!*"
    )

    users = get_stored_users()
    thanh_cong = 0
    that_bai = 0

    for user_id in users:
        try:
            await context.bot.send_message(chat_id=int(user_id), text=tin_nhan_tong, parse_mode=ParseMode.MARKDOWN)
            thanh_cong += 1
        except Exception:
            that_bai += 1

    await update.message.reply_text(f"🚀 *Đã phát lệnh thành công!*\n\n✅ Gửi đến: `{thanh_cong}` người\n❌ Thất bại: `{that_bai}` người.", parse_mode=ParseMode.MARKDOWN)


def main() -> None:
    application = Application.builder().token(TOKEN).build()
    
    application.add_handler(CommandHandler("start", start))
    application.add_handler(CommandHandler("admin", admin_panel))
    application.add_handler(CommandHandler("baolenh", baolenh))
    
    # Bộ lắng nghe sự kiện bấm nút trên bảng điều khiển
    application.add_handler(CallbackQueryHandler(admin_button_click))
    
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))

    # CẤU HÌNH WEBHOOK CHO RENDER
    PORT = int(os.environ.get('PORT', 8443))
    RENDER_URL = os.environ.get('RENDER_EXTERNAL_URL')

    if RENDER_URL:
        logger.info(f"Starting webhook on port {PORT} with URL {RENDER_URL}")
        application.run_webhook(
            listen="0.0.0.0",
            port=PORT,
            url_path=TOKEN,
            webhook_url=f"{RENDER_URL}/{TOKEN}"
        )
    else:
        logger.info("Starting local polling...")
        application.run_polling()

if __name__ == '__main__':
    main()
