    users = get_stored_users()
    group_status = "🟢 Đã kết nối thành công" if get_group_id() else "🔴 Chưa kết nối nhóm"
    return (
        f"⚙️ *BẢNG ĐIỀU KHIỂN QUẢN TRỊ VIÊN*\n"
        f"--------------------------------------\n"
        f"👤 *Admin:* @{ADMIN_USERNAME}\n"
        f"🌐 *Trạng thái nhóm:* {group_status}\n"
        f"👥 *Tổng số người tham gia:* `{len(users)}` người\n\n"
        f"📢 *CÚ PHÁP PHÁT LỆNH HÀNG LOẠT:*\n"
        f"`/baolenh [Số_Phiên] [TAI/XIU]`"
