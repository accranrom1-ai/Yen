def is_admin(update: Update) -> bool:
    user = update.effective_user
    if user and user.username:
        return user.username.lower() == ADMIN_USERNAME.lower()
    return False

def get_stored_users():
    if not os.path.exists(USER_FILE):
        return set()
    with open(USER_FILE, "r") as f:
        return set(line.strip() for line in f if line.strip())

def save_user(user_id):
    users = get_stored_users()
    if str(user_id) not in users:
        with open(USER_FILE, "a") as f:
            f.write(f"{user_id}\n")

# Hàm đọc ID nhóm được lưu tự động
def get_group_id():
    if os.path.exists(GROUP_ID_FILE):
        with open(GROUP_ID_FILE, "r") as f:
            return f.read().strip()
    return None

# --- TỰ ĐỘNG LẤY ID KHI ĐƯỢC THÊM VÀO NHÓM ---
async def track_chats(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not update.my_chat_member:
        return
    chat = update.my_chat_member.chat
    status = update.my_chat_member.new_chat_member.status
    
    # Nếu bot được thêm vào nhóm hoặc được lên làm Admin
    if status in ["administrator", "member"]:
        with open(GROUP_ID_FILE, "w") as f:
            f.write(str(chat.id))
        logger.info(f"🤖 Đã tự động kích hoạt và lưu ID nhóm: {chat.id}")
        try:
            await context.bot.send_message(
                chat_id=chat.id,
                text=f"🤖 *Neural Matrix Bot Kích Hoạt Thành Công!*\n\nHệ thống đã tự động đồng bộ nhóm này làm nhóm bắt buộc tham gia.",
                parse_mode=ParseMode.MARKDOWN
            )
        except Exception:
            pass

# --- HÀM KIỂM TRA THÀNH VIÊN NHÓM ---
async def check_membership(update: Update, context: ContextTypes.DEFAULT_TYPE) -> bool:
    user_id = update.effective_user.id
    if is_admin(update):
        return True
        
    group_id = get_group_id()
    if not group_id:
        # Nếu bot chưa được thêm vào nhóm nào, tạm thời cho mọi người dùng để tránh lỗi
        return True

    try:
        member = await context.bot.get_chat_member(chat_id=int(group_id), user_id=user_id)
        if member.status in ['member', 'administrator', 'creator', 'owner']:
            return True
    except Exception as e:
        logger.error(f"Lỗi check member: {e}")

    keyboard = [
        [InlineKeyboardButton("🔹 Tham gia nhóm tại đây", url=GROUP_LINK)],
        [InlineKeyboardButton("✅ Tôi đã tham gia (Xác minh)", callback_data="check_again")]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    
    msg_text = (
        "⚠️ *YÊU CẦU THAM GIA NHÓM CHÍNH THỨC*\n\n"
        "Toàn bộ tính năng phân tích ma trận dữ liệu đã bị khóa. Bạn vui lòng tham gia vào nhóm của chúng tôi để tiếp tục sử dụng."
    )
    
    if update.callback_query:
        await update.callback_query.message.reply_text(msg_text, parse_mode=ParseMode.MARKDOWN, reply_markup=reply_markup)
    else:
        await update.message.reply_text(msg_text, parse_mode=ParseMode.MARKDOWN, reply_markup=reply_markup)
    return False

# Thuật toán xử lý ma trận
def process_neural_matrix(hash_str: str) -> str:
    hash_str = hash_str.strip().lower().replace(" ", "")
    if not re.match(r"^[0-9a-f]+$", hash_str):
        return "❌ *Chuỗi không hợp lệ!* Chỉ chấp nhận ký tự chuẩn Hex (0-9, a-f)."
    length = len(hash_str)
    if length not in (32, 64):
        return "⚠️ *Sai cấu trúc dữ liệu!* Hệ thống chỉ hỗ trợ MD5 (32 ký tự) hoặc SHA-256 (64 ký tự)."

    nibbles = [int(char, 16) for char in hash_str]
    matrix_score = 0.0
    cols = 8
    rows = length // cols

    for r in range(rows):
        matrix_score += 1.5 if (nibbles[(r * cols) + (r % cols)] % 2 == 0) else -1.5
        matrix_score += 1.2 if (nibbles[(r * cols) + ((cols - 1 - r) % cols)] % 2 == 0) else -1.2

    choice = "🔴 TÀI" if matrix_score > 0 else "🟢 XỈU" if matrix_score < 0 else "⚪ BỎ QUA"
    type_label = "MD5" if length == 32 else "SHA-256"
    sigmoid_rate = 50 + (49.6 / (1 + math.exp(-0.5 * (abs(matrix_score) - 2))))

    return (
        f"📊 *KẾT QUẢ PHÂN TÍCH MA TRẬN KHỐI*\n"
        f"--------------------------------------\n"
        f"🔹 *Loại chuỗi:* {type_label}\n"
        f"🔮 *Gợi ý:* {choice}\n"
        f"🎯 *Độ tin cậy:* `{sigmoid_rate:.1f}%`"
    )

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    save_user(update.effective_chat.id)
    if not await check_membership(update, context):
        return
    await update.message.reply_text(
        "🤖 *Neural Matrix Engine Bot Đã Sẵn Sàng!*\n\nGửi mã MD5/SHA-256 để phân tích.",
        parse_mode=ParseMode.MARKDOWN,
        reply_markup=ReplyKeyboardRemove()
    )

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    save_user(update.effective_chat.id)
    if not await check_membership(update, context):
        return
    response = process_neural_matrix(update.message.text)
    await update.message.reply_text(response, parse_mode=ParseMode.MARKDOWN)

